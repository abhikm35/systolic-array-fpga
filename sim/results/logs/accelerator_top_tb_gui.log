xcelium> 
xcelium> source /tools/software/cadence/xcelium/latest/tools/xcelium/files/xmsimrc
xcelium> # Waveform probes for accelerator_top_tb
xcelium> # Focus: UART C-read reply (4-byte burst) and host_uart_cmd <-> uart_tx handshake
xcelium> #
xcelium> # What to look for (zoom to first 'C' read after compute finishes):
xcelium> #   - u_host_cmd.state enters CMD_TX_BYTE
xcelium> #   - tx_byte_idx steps 0 -> 1 -> 2 -> 3 once per completed UART frame
xcelium> #   - tx_valid pulses once per byte; tx_busy rises shortly after each pulse
xcelium> #   - tx_done (busy falling edge) should precede the next tx_valid (fixed RTL)
xcelium> #   - uart_tx shows four back-to-back serial frames on the wire
xcelium> 
xcelium> database -open waves -shm -default
